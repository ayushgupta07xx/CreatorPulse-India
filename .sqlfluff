[sqlfluff]
dialect = postgres
templater = dbt
max_line_length = 100
exclude_rules = ST06, AM03, RF04

[sqlfluff:templater:dbt]
project_dir = warehouse/dbt_project
profiles_dir = warehouse/dbt_project
profile = creatorpulse
target = dev

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = lower
